# ── MCP server (Vercel function) ─────────────────────────────────────────────
# Server-side only. Set these as Environment Variables in the Vercel project
# (Project → Settings → Environment Variables). Never expose the service-role key.

# Optional — defaults to the app's Supabase project URL.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Required — Supabase service-role key (Dashboard → Settings → API).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
